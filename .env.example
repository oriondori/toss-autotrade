# 이 파일을 .env 로 복사한 뒤 실제 값을 입력하세요.
# .env 는 절대 git에 커밋하지 마세요.
TOSS_CLIENT_ID=여기에_client_id
TOSS_CLIENT_SECRET=여기에_client_secret

# 텔레그램 알림 (선택 — 비워두면 알림 비활성)
# 1. @BotFather 에서 /newbot 으로 봇 생성 → BOT_TOKEN 발급
# 2. 봇에게 메시지 보낸 뒤 https://api.telegram.org/bot<TOKEN>/getUpdates 에서 chat_id 확인
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
